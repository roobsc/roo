{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "server.js": {
      "includeFiles": [
        "index.html",
        "styles.css",
        "app.js",
        "config.js",
        "assets/**",
        "contracts/**",
        "build-vanity/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
